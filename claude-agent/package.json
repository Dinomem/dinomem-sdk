{
  "name": "@agentmem/claude-agent",
  "version": "0.1.2",
  "description": "AgentMem integration for the Claude Agent SDK — in-process MCP server + auto-recall hook",
  "license": "Apache-2.0",
  "author": "rooney011 <bvsa2020@gmail.com>",
  "homepage": "https://agentmem-dashboard.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rooney011/agentmem-sdk.git",
    "directory": "claude-agent"
  },
  "bugs": {
    "url": "https://github.com/rooney011/agentmem-sdk/issues"
  },
  "keywords": [
    "anthropic",
    "claude",
    "claude-agent-sdk",
    "ai",
    "agents",
    "memory",
    "mcp"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import=tsx test/*.test.ts"
  },
  "dependencies": {
    "@agentmem/sdk": "^0.8.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.3.0 <0.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.144",
    "@types/node": "^20.0.0",
    "tsup": "8.3.5",
    "tsx": "^4.0.0",
    "typescript": "5.8.3",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
