{
  "name": "@dinomem/mastra",
  "version": "1.0.0",
  "description": "DinoMem integration for Mastra — memory tools for any Mastra agent",
  "license": "Apache-2.0",
  "author": "DinoMem",
  "homepage": "https://dinomem-dashboard.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DinoMem/dinomem-sdk.git",
    "directory": "mastra"
  },
  "bugs": {
    "url": "https://github.com/DinoMem/dinomem-sdk/issues"
  },
  "keywords": [
    "mastra",
    "ai",
    "agents",
    "memory",
    "rag",
    "integration"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import=tsx test/*.test.ts"
  },
  "dependencies": {
    "@dinomem/sdk": "workspace:^"
  },
  "peerDependencies": {
    "@mastra/core": ">=0.15.3 <0.18.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@mastra/core": "^0.16.0",
    "@types/node": "^20.0.0",
    "tsup": "8.3.5",
    "tsx": "^4.0.0",
    "typescript": "5.8.3",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18"
  }
}
